  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!--  PAGE 1 — Topology overview                                              -->
  <!--  Hub VNet (control plane) + production spoke VNets + on-prem via ExR     -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <diagram name="1 — Topology overview" id="topology">
    <mxGraphModel dx="2400" dy="1700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2400" pageHeight="1700" math="0" shadow="0" background="#FFFFFF">
