        <mxCell id="spoke1-note" value="Each VM runs Send-PerfToEventHub.ps1 (60s scheduled task) → telemetry via hub PE → Event Hubs.&#10;Hybrid Worker pulls runbook jobs from Automation Account (via hub PE) and executes them locally on the VM." style="text;html=1;align=center;verticalAlign=middle;fontSize=10;fontStyle=2;fontColor=#444444;" vertex="1" parent="1">
          <mxGeometry x="720" y="490" width="700" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="spoke1-route" value="Routes outbound traffic to Hub via VNet peering — no PEs in spoke (centralized PE pattern)" style="text;html=1;align=center;verticalAlign=middle;fontSize=10;fontStyle=2;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="720" y="600" width="700" height="40" as="geometry"/>
        </mxCell>

