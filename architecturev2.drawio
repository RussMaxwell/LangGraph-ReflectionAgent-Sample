        <!-- ── Title ── -->
        <mxCell id="title" value="IIS Auto-Healing — Multi-VNet Topology (Arca-Secured)" style="text;html=1;align=center;verticalAlign=middle;fontSize=22;fontStyle=1;fontColor=#1F3864;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="2320" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="subtitle" value="Hub VNet hosts Function App + all PEs · Production IIS VMs live in spoke VNets and on-prem · Telemetry → Event Hubs · Runbooks executed locally by Hybrid Workers on each VM" style="text;html=1;align=center;verticalAlign=middle;fontSize=12;fontStyle=2;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="40" y="60" width="2320" height="24" as="geometry"/>
        </mxCell>

        <!-- ── PUBLIC strip ── -->
